# Public site origin used for canonical URLs, Open Graph, and JSON-LD.
# Must match the live domain (no trailing slash).
VITE_SITE_URL=https://ynh.co.za

# Contact form (EmailJS — free tier: 200 emails/month, no credit card)
# 1. Sign up at https://www.emailjs.com
# 2. Add an Email Service (e.g. Gmail) and copy the Service ID
# 3. Create a template with To Email = madimetjaterencechuene@gmail.com
#    and variables: {{from_name}}, {{from_email}}, {{phone}}, {{subject}},
#    {{message}}, {{reply_to}}
# 4. Copy Template ID and Public Key (Account → API Keys)
# 5. Paste them below, then restart `npm run dev`
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
